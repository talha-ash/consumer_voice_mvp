      "id": "z5trWVCxeyYwzTKxPJoKZ",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": -2450.712459820864,
      "y": 6913.165514019522,
      "strokeColor": "#1e1e1e",
