    {
      "type": "text",
      "version": 990,
      "versionNonce": 1329640773,
      "isDeleted": false,
      "id": "bLI6pwoWOmU_LpCSJdUXS",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 993.6754842315572,
      "y": 7946.258038017444,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "width": 1350.576416015625,
      "height": 495,
      "seed": 603419655,
      "groupIds": [
        "MA58YcjpMKMGRfto8rIaI"
      ],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1717420461397,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 1,
      "text": "On Client channel we call action onCallActive from \nclient store which update state specialy store the SDP\nof employee used by webrtc to make p2p between parties\nalso set callActive state to true.In Component we have effect \nwhich run on callActive state change  when it run and \ncallActive is true initate webrtc stuff also pass employee SDP to webrtc.\nAnd gets Its on SDP which we need to send it to employee to make P2P \nconnection complete.After that we call action onClientConnectionData from \neployee store. This action send message to client channel with its SDP, \ncompany Id , employee id. we send employee id to access active calls in \ncompamy server state.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On Client channel we call action onCallActive from \nclient store which update state specialy store the SDP\nof employee used by webrtc to make p2p between parties\nalso set callActive state to true.In Component we have effect \nwhich run on callActive state change  when it run and \ncallActive is true initate webrtc stuff also pass employee SDP to webrtc.\nAnd gets Its on SDP which we need to send it to employee to make P2P \nconnection complete.After that we call action onClientConnectionData from \neployee store. This action send message to client channel with its SDP, \ncompany Id , employee id. we send employee id to access active calls in \ncompamy server state.",
      "lineHeight": 1.25,
      "baseline": 482
    },
