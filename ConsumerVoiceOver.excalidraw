      "boundElements": [],
      "updated": 1717420461401,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 1,
      "text": "On Client drop implicitly mean client closed tab or system held whatever \nreason .So with this client disconnect from channels .So in client company \nchannel we use terminate callback to detect this disconnect .In this \ncallback we cast to company server on_client_offline with client id\n\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On Client drop implicitly mean client closed tab or system held whatever \nreason .So with this client disconnect from channels .So in client company \nchannel we use terminate callback to detect this disconnect .In this \ncallback we cast to company server on_client_offline with client id\n\n",
      "lineHeight": 1.25,
      "baseline": 257
    },
