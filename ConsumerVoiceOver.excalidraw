          "type": "arrow"
        }
      ],
      "updated": 1717420461400,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 1,
      "text": "On Client or Employee Drop call explicitly we clear webrtc stuff\ncall action from respective store(client, employee) dropcall which clear \nstore state related to call and send message to respective channel\nemployee_drop_call with payload client id or employee id if employee\ndrop call\n\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On Client or Employee Drop call explicitly we clear webrtc stuff\ncall action from respective store(client, employee) dropcall which clear \nstore state related to call and send message to respective channel\nemployee_drop_call with payload client id or employee id if employee\ndrop call\n\n",
      "lineHeight": 1.25,
      "baseline": 302
    },
