      "roundness": null,
      "boundElements": [],
      "updated": 1717420461394,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 1,
      "text": "On Employee side employee channel class recice this message\nand call onClientCall action of employee store. Then Popup open\nand employee have choice to accept call or not(** not handle on reject call)\nAfter client accept call. We initiate webrtc stuff and call onAcceptCall action\nof employee store with SDP(employeeConnectionData) info. This action then send\nmessage back to employee channel employee_accept_call with client id and SDP\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On Employee side employee channel class recice this message\nand call onClientCall action of employee store. Then Popup open\nand employee have choice to accept call or not(** not handle on reject call)\nAfter client accept call. We initiate webrtc stuff and call onAcceptCall action\nof employee store with SDP(employeeConnectionData) info. This action then send\nmessage back to employee channel employee_accept_call with client id and SDP\n",
      "lineHeight": 1.25,
      "baseline": 302
    },
