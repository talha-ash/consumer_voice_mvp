    {
      "type": "text",
      "version": 423,
      "versionNonce": 1764616197,
      "isDeleted": false,
      "id": "yK49KxNOD9FcCwE4OqQyM",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 3627.2080475674647,
      "y": 6895.322029768733,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "width": 944.1002197265625,
