    {
      "type": "text",
      "version": 630,
      "versionNonce": 227136133,
      "isDeleted": false,
      "id": "kvGQR5a_L0TZ4zyl9DBRo",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": 280,
      "y": 10080,
