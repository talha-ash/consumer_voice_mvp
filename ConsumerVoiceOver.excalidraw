    {
      "type": "text",
      "version": 763,
      "versionNonce": 1526968747,
      "isDeleted": false,
      "id": "Gfswg0CJOQH9hVkcdZyAs",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": -1580,
      "y": 9120,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "width": 1738.1884765625,
      "height": 495,
      "seed": 1485047241,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1717420461394,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 1,
      "text": "This func gonna find that if company state have\nany idle employee if no return no employee available(**)\nBut if idle employee found then it update company state\n1. company Status if we still have idle employee in state\n2. idle_employee decreament because we gonna consume one idle employee\n3. Update employee status to busy so update online_employee_list\n4. Also Add entry to active_calls which is map where key is ids of client\nand employee  %{ employee_id: employee_id, client_id: client_id, status: @call_status_initiated}\n\nReturn updated State\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This func gonna find that if company state have\nany idle employee if no return no employee available(**)\nBut if idle employee found then it update company state\n1. company Status if we still have idle employee in state\n2. idle_employee decreament because we gonna consume one idle employee\n3. Update employee status to busy so update online_employee_list\n4. Also Add entry to active_calls which is map where key is ids of client\nand employee  %{ employee_id: employee_id, client_id: client_id, status: @call_status_initiated}\n\nReturn updated State\n",
      "lineHeight": 1.25,
      "baseline": 482
    },
