      "roundness": null,
      "boundElements": [],
      "updated": 1717420461399,
      "link": null,
      "locked": false,
      "fontSize": 36,
      "fontFamily": 1,
      "text": "Things To Improve\n1. Get webrtc stuff out of components.\n\n2. Send Client SDP on call initiate instead of later.\n\n3. Store SDP In Company Server Too.\n\n4. Correct Events Name also namespace\n\n5. Store active call state in browser too.Help in \nsimplify some stuff.\n\n6. And use active call key when drop call so comapny\nserver use this key to clear data and brodcast\nmessage to other party.\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Things To Improve\n1. Get webrtc stuff out of components.\n\n2. Send Client SDP on call initiate instead of later.\n\n3. Store SDP In Company Server Too.\n\n4. Correct Events Name also namespace\n\n5. Store active call state in browser too.Help in \nsimplify some stuff.\n\n6. And use active call key when drop call so comapny\nserver use this key to clear data and brodcast\nmessage to other party.\n",
      "lineHeight": 1.25,
      "baseline": 707
    },
    {
      "type": "text",
      "version": 312,
      "versionNonce": 1997031115,
      "isDeleted": false,
      "id": "nmmvvG35QPUdXBfLDwJEr",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "x": -2854.791952432537,
      "y": 11160.155363102069,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "width": 1257.15625,
      "height": 315,
      "seed": 436739849,
      "groupIds": [
        "bUbNcg28cEYJWdZZlZYSX"
      ],
      "frameId": null,
      "roundness": null,
